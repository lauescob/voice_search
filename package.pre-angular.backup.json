{
  "name": "tu360inmobiliario",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "start:all": "cross-env IP=192.168.58.121 node start-all.js",
    "start:shell": "npx nx serve shell --devRemotes=mf-cotidianidad,mf-online-payments,mf-coba,mf-core --disable-host-check  --configuration local ",
    "start:cotidianidad": "npx nx serve mf-cotidianidad --disable-host-check  --configuration local ",
    "start:online-payments": "npx nx serve mf-online-payments --disable-host-check  --configuration local ",
    "start:coba": "npx nx serve mf-coba --disable-host-check  --configuration local ",
    "start:core": "npx nx serve mf-core --disable-host-check  --configuration local ",
    "test:shell": "npx nx test shell",
    "test:mf-cotidianidad": "npx nx test mf-cotidianidad",
    "test:mf-online-payments": "npx nx test mf-online-payments",
    "test:mf-coba": "npx nx test mf-coba",
    "test:mf-core": "npx nx test mf-core",
    "build:shell": "npx nx build shell --baseHref=/inmobiliario/ --configuration production",
    "build:mf-cotidianidad": "npx nx build mf-cotidianidad --baseHref=/inmobiliario/ --configuration production",
    "build:mf-online-payments": "npx nx build mf-online-payments --baseHref=/inmobiliario/ --configuration production",
    "build:mf-coba": "npx nx build mf-coba --baseHref=/inmobiliario/ --configuration production",
    "build:mf-core": "npx nx build mf-core --baseHref=/inmobiliario/ --configuration production",
    "format:mf-coba": "prettier --config apps/mf-coba/.prettierrc \"apps/mf-coba/**/*.{ts,js,json,scss,html,md}\" --write",
    "lint:mf-coba": "nx lint mf-coba --fix",
    "format:mf-core": "prettier --config apps/mf-core/.prettierrc \"apps/mf-core/**/*.{ts,js,json,scss,html,md}\" --write",
    "lint:mf-core": "nx lint mf-core --fix",
    "prepare": "husky install",
    "commit": "cz"
  },
